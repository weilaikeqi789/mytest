-- ============================================================================
-- 标签标题事件处理器
-- 美化版：渐变效果、主题色、清晰的状态区分
-- ============================================================================

local wezterm = require("wezterm")
local theme_manager = require("colors.themes")
local theme = theme_manager.get_theme()

-- ============================================================================
-- 图标定义（使用 Nerd Font 图标）
-- ============================================================================
local SOLID_LEFT = ""          -- 左箭头
local SOLID_RIGHT = ""         -- 右箭头
local ICON_UNSEEN = "●"          -- 未读提示
local ICON_ADMIN = " "          -- 管理员图标

-- ============================================================================
-- 进程图标映射（简洁风格）
-- ============================================================================
